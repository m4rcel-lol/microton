# Microton Docker Compose environment.
# Copy this file to .env and fill every required secret before starting.

# Compose/runtime
COMPOSE_PROJECT_NAME=microton
MICROTON_ENV_FILE=.env
MICROTON_IMAGE=microton-web:latest
MICROTON_STREAMING_IMAGE=microton-streaming:latest
MICROTON_VERSION_METADATA=microton
WEB_BIND=127.0.0.1
WEB_PORT=40122
STREAMING_BIND=127.0.0.1
STREAMING_PORT=13368

# Federation
# This identifies your server and cannot be changed safely later.
LOCAL_DOMAIN=example.com
# WEB_DOMAIN=example.com
LOCAL_HTTPS=true
# STREAMING_API_BASE_URL=wss://example.com
WEB_AUTHN_RP_NAME=Microton
SERVER_SOFTWARE_NAME=Microton

# Lightweight defaults for a small instance. Raise these as traffic grows.
WEB_CONCURRENCY=1
MAX_THREADS=5
SIDEKIQ_CONCURRENCY=3
DB_POOL=5

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# PostgreSQL
DB_HOST=db
DB_PORT=5432
DB_NAME=mastodon_production
DB_USER=mastodon
DB_PASS=
POSTGRES_SHM_SIZE=256mb

# Search is disabled by default. To enable it, set ES_ENABLED=true and start
# Compose with: docker compose --profile search up -d
ES_ENABLED=false
ES_HOST=es
ES_PORT=9200
# ES_USER=elastic
# ES_PASS=password

# Local filesystem storage is the default lightweight deployment mode.
S3_ENABLED=false
# S3_BUCKET=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# S3_ALIAS_HOST=

# Required application secrets. Generate unique values for every deployment.
SECRET_KEY_BASE=
ACTIVE_RECORD_ENCRYPTION_DETERMINISTIC_KEY=
ACTIVE_RECORD_ENCRYPTION_KEY_DERIVATION_SALT=
ACTIVE_RECORD_ENCRYPTION_PRIMARY_KEY=
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=

# Mail
# Leave SMTP_ENABLED=false for private/local deployments that do not send mail.
# Users will not receive confirmation, reset, notification, or admin e-mails.
SMTP_ENABLED=false
SMTP_SERVER=
SMTP_PORT=587
SMTP_LOGIN=
SMTP_PASSWORD=
SMTP_FROM_ADDRESS=notifications@example.com

# Logs and retention
RAILS_LOG_LEVEL=info
IP_RETENTION_PERIOD=31556952
SESSION_RETENTION_PERIOD=31556952
